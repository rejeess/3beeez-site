# ── Required ──────────────────────────────────────────────────────────────────

# Anthropic API key (used for Claude answer synthesis)
ANTHROPIC_API_KEY=sk-ant-...

# ── Production database (pgvector) ───────────────────────────────────────────
# Set all three to enable dense-vector retrieval (pgvector path).
# If omitted, the app falls back to SQLite sparse-vector retrieval.

DATABASE_URL=postgresql://user:password@host:5432/dbname
HF_API_TOKEN=hf_...
HF_EMBEDDING_API_URL=https://api-inference.huggingface.co/models/intfloat/multilingual-e5-large
# HF_EMBEDDING_PROMPT_MODE=e5   # default; use "none" to send raw text

# ── Optional hosted LLM (alternative to Claude) ───────────────────────────────
# LLM_API_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-...
# LLM_MODEL=gpt-4o-mini

# ── Purchase / billing ────────────────────────────────────────────────────────
# PURCHASE_MODE=production          # enables real payment redirect
# PURCHASE_PROVIDER_URL=https://...  # payment provider checkout URL

# ── App URLs and email ────────────────────────────────────────────────────────
APP_BASE_URL=https://3beeez.com

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=you@example.com
SMTP_PASS=yourpassword
SMTP_FROM=3Beeez <noreply@3beeez.com>

# ── pgvector dimensions (must match your HF embedding model) ──────────────────
# PGVECTOR_DIMENSIONS=1024   # default; change only if you switch models
